{
  "name": "eslint-plugin-ariel",
  "type": "module",
  "version": "0.1.1",
  "packageManager": "bun@1.3.10",
  "description": "A collection of ESLint rules.",
  "author": "Ariel Salgado <ariel.salgado.acevedo@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ariel-salgado/eslint-plugin-ariel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariel-salgado/eslint-plugin-ariel.git"
  },
  "keywords": [
    "eslint-plugin"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "release": "sh ./scripts/release.sh",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@typescript-eslint/utils": "^8.56.0",
    "eslint": "^10.0.0",
    "typescript": "~5.9.3"
  },
  "devDependencies": {
    "@ariel-salgado/eslint-config": "0.5.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/typescript-estree": "8.59.1",
    "@typescript-eslint/utils": "8.59.1",
    "@typescript/native-preview": "7.0.0-dev.20260428.1",
    "bumpp": "11.0.1",
    "eslint": "10.2.1",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  },
  "resolutions": {
    "eslint": "^10.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
