{
  "name": "eslint-plugin-ariel",
  "type": "module",
  "version": "0.0.3",
  "packageManager": "bun@1.3.10",
  "description": "A collection of ESLint rules.",
  "author": "Ariel Salgado <ariel.salgado.acevedo@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ariel-salgado/eslint-plugin-ariel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariel-salgado/eslint-plugin-ariel.git"
  },
  "keywords": [
    "eslint-plugin"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "release": "bumpp && bun publish",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "eslint": "*"
  },
  "devDependencies": {
    "@ariel-salgado/eslint-config": "0.5.0",
    "@types/node": "25.3.5",
    "@typescript-eslint/utils": "8.56.1",
    "@typescript/native-preview": "7.0.0-dev.20260308.1",
    "bumpp": "10.4.1",
    "eslint": "10.0.3",
    "tsdown": "0.21.0",
    "typescript": "5.9.3"
  },
  "workspaces": {
    "catalog": {
      "@ariel-salgado/eslint-config": "^0.5.0",
      "@types/node": "^25.3.5",
      "@typescript-eslint/utils": "^8.56.1",
      "@typescript/native-preview": "7.0.0-dev.20260308.1",
      "bumpp": "^10.4.1",
      "eslint": "^10.0.3",
      "tsdown": "^0.21.10",
      "typescript": "^5.9.3"
    }
  }
}
